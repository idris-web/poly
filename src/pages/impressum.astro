---
import Layout from '../layouts/Layout.astro';
---

<Layout title="POLIGAMIA | Impressum">
  <main class="page-content">
    <section class="placeholder">
      <h1>Impressum</h1>
      <p>Dieser Bereich ist vorbereitet. Die Inhalte werden hier eingepflegt, sobald Sie den Text bereitstellen.</p>
    </section>
  </main>
</Layout>

<style>
  .page-content {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
  }

  .placeholder h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4vw, 3rem);
    margin-bottom: 1rem;
    color: #fff;
  }

  .placeholder p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
  }
</style>
