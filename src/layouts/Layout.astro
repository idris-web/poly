---
interface Props {
  title: string;
}

const { title } = Astro.props;
const description =
  'POLIGAMIA - Ein Parfümhaus für Kenner. Für Ästheten. Für jene, die nicht fragen, sondern verstehen. Not for Everybody.';
const canonical = 'https://poligamia.com';
const featuredImage = '/hero-featured.webp';
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="handheldfriendly" content="true" />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Preload Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="image" href={featuredImage} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={featuredImage} />
    <meta property="og:image:alt" content="POLIGAMIA hero fragrance experience" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={featuredImage} />
    <meta name="twitter:image:alt" content="POLIGAMIA hero fragrance experience" />
    <script
      id="Cookiebot"
      src="https://consent.cookiebot.com/uc.js"
      data-cbid="29410cb4-eaf1-455a-b4a3-4aec16faefe1"
      data-blockingmode="auto"
      type="text/javascript"
    ></script>
  </head>
  <body>
    <div class="noise-overlay"></div>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
