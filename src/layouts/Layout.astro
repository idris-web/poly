---
interface Props {
  title: string;
}

const { title } = Astro.props;
const description =
  'Exklusive Düfte für diejenigen, die es wagen, anders zu sein.';
const canonical = 'https://poligamia.eu';
const featuredImage = '/poligamia-hero-featured.webp';
const siteName = 'POLIGAMIA';
const productName = 'Poligamia Exordium';
const productDescription =
  'Poligamia Exordium – ein charakterstarker Duft mit würzigen, harzigen und holzigen Noten. Entwickelt für Persönlichkeiten, die Grenzen überschreiten.';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: canonical,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${canonical}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const productStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: productName,
  description: productDescription,
  image: `${canonical}${featuredImage}`,
  brand: {
    '@type': 'Brand',
    name: siteName,
  },
};
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="handheldfriendly" content="true" />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/poligamia-favicon.svg" sizes="any" type="image/svg+xml" />
    <link rel="icon" href="/poligamia-favicon.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/poligamia-favicon.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/poligamia-apple-touch-icon.png" />
    <link rel="shortcut icon" href="/poligamia-favicon.svg" />
    <link rel="mask-icon" href="/poligamia-logo-icon.svg" color="#0c0a09" />
    <title>{title}</title>

    <!-- Preload Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="image" href={featuredImage} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${canonical}${featuredImage}`} />
    <meta property="og:image:alt" content="POLIGAMIA hero fragrance experience" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonical}${featuredImage}`} />
    <meta name="twitter:image:alt" content="POLIGAMIA hero fragrance experience" />
    <meta property="og:site_name" content={siteName} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(productStructuredData)}></script>

    <script>
      window.OsanoConfig = {
        language: 'de',
        countryDetection: false,
        policyUrl: '/datenschutz',
        // The actual Osano site ID is required for a production setup.
        // Replace "your-osano-site-id" with your account ID once available.
        osanoSiteId: 'your-osano-site-id',
        disableBanner: true,
      };
    </script>
    <script
      src="https://cdn.cookieconsent.osano.com/consent/6.6.1/osano.js"
      async
    ></script>
  </head>
  <body>
    <div class="noise-overlay"></div>
    <slot />

    <div id="cookie-banner" class="cookie-banner" role="dialog" aria-modal="true" aria-labelledby="cookie-title">
      <div class="cookie-card">
        <h2 id="cookie-title">Cookie-Einstellungen</h2>
        <p>
          Für den Betrieb dieser Website verwenden wir notwendige Cookies. Weitere Kategorien werden erst nach Ihrer Zustimmung aktiviert.
        </p>
        <div class="cookie-actions">
          <button type="button" class="cookie-btn primary" data-action="accept-all">Alle akzeptieren</button>
          <button type="button" class="cookie-btn ghost" data-action="reject-all">Alle ablehnen</button>
          <button type="button" class="cookie-btn secondary" data-action="open-settings">Einstellungen</button>
        </div>
      </div>
    </div>

    <div id="cookie-settings" class="cookie-settings" role="dialog" aria-modal="true" aria-labelledby="cookie-settings-title" aria-hidden="true">
      <div class="cookie-card">
        <h2 id="cookie-settings-title">Cookie-Einstellungen anpassen</h2>
        <p>Wählen Sie hier, welche Kategorien optionaler Cookies Sie erlauben möchten.</p>
        <div class="cookie-options">
          <label class="cookie-option">
            <input type="checkbox" checked disabled />
            <span class="cookie-label">Notwendig</span>
            <span class="cookie-desc">Erforderlich für die grundlegende Funktionalität der Seite.</span>
          </label>
          <label class="cookie-option">
            <input type="checkbox" id="cookie-analytics" />
            <span class="cookie-label">Statistik</span>
            <span class="cookie-desc">Hilft uns, die Nutzung besser zu verstehen und Inhalte zu verbessern.</span>
          </label>
          <label class="cookie-option">
            <input type="checkbox" id="cookie-marketing" />
            <span class="cookie-label">Marketing</span>
            <span class="cookie-desc">Erlaubt personalisierte Inhalte und externe Dienste wie EmailJS.</span>
          </label>
        </div>
        <div class="cookie-actions">
          <button type="button" class="cookie-btn primary" data-action="save-settings">Auswahl speichern</button>
          <button type="button" class="cookie-btn ghost" data-action="close-settings">Abbrechen</button>
        </div>
      </div>
    </div>

    <button type="button" id="cookie-settings-button" class="cookie-settings-button" aria-haspopup="dialog" aria-label="Cookie-Einstellungen öffnen">
      <span class="sr-only">Cookie-Einstellungen</span>
      <svg class="cookie-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M12 2a10 10 0 1 1-8.6 5.1c.9.5 2 .4 2.8-.2 1-.8 1.5-2 1.4-3.2.4.2.9.3 1.4.3 1.7 0 3-1.3 3-3Z"
          fill="currentColor"
        />
        <circle cx="15.2" cy="7.5" r="1.3" fill="#0f0f0f" />
        <circle cx="9" cy="9.5" r="1.1" fill="#0f0f0f" />
        <circle cx="7.8" cy="14.2" r="1" fill="#0f0f0f" />
        <circle cx="13" cy="15.4" r="1.15" fill="#0f0f0f" />
      </svg>
    </button>

    <script type="text/javascript">
      (() => {
        const CONSENT_KEY = 'poligamia_osano_consent';
        const EMAILJS_PUBLIC_KEY = 'U38CXB8gbjNn3IeGU';
        const optionalScripts = [
          {
            category: 'marketing',
            src: 'https://cdn.emailjs.com/dist/email.min.js',
            loaded: false,
          },
        ];
        const banner = document.getElementById('cookie-banner');
        const settingsPanel = document.getElementById('cookie-settings');
        const settingsButton = document.getElementById('cookie-settings-button');
        const analyticsToggle = document.getElementById('cookie-analytics');
        const marketingToggle = document.getElementById('cookie-marketing');

        const setCookie = (name, value, days) => {
          const maxAge = days ? `; max-age=${days * 86400}` : '';
          const secure = window.location.protocol === 'https:' ? '; Secure' : '';
          document.cookie = `${name}=${value}; path=/; SameSite=Lax${secure}${maxAge}`;
        };

        const readConsentFromCookie = () => {
          const nameEq = `${CONSENT_KEY}=`;
          const cookies = document.cookie.split('; ');
          const match = cookies.find((cookie) => cookie.startsWith(nameEq));
          if (!match) return null;
          const [, value] = match.split('=');
          if (!value) return null;
          try {
            return JSON.parse(decodeURIComponent(value));
          } catch {
            return null;
          }
        };

        const interpretConsent = (value) => {
          if (typeof value === 'boolean') return value;
          if (typeof value === 'string') {
            const normalized = value.toLowerCase();
            return ['accepted', 'allow', 'granted', 'true', '1'].includes(normalized);
          }
          if (value && typeof value === 'object') {
            if ('status' in value) return interpretConsent(value.status);
            if ('value' in value) return interpretConsent(value.value);
            if ('state' in value) return interpretConsent(value.state);
          }
          if (Array.isArray(value)) {
            return value.some((entry) => interpretConsent(entry));
          }
          return false;
        };

        const saveConsent = (consent) => {
          try {
            localStorage.setItem(CONSENT_KEY, JSON.stringify(consent));
          } catch {
            // ignore storage failures
          }
          setCookie(CONSENT_KEY, JSON.stringify(consent), 180);
        };

        const loadConsent = () => {
          try {
            const stored = localStorage.getItem(CONSENT_KEY);
            if (stored) {
              return JSON.parse(stored);
            }
          } catch {
            // ignore
          }
          return readConsentFromCookie();
        };

        const getOsanoCategory = (category) => {
          const osano = window.Osano || window.osano;
          if (!osano) return undefined;
          if (typeof osano.getConsent === 'function') {
            return osano.getConsent(category);
          }
          if (osano.consent && typeof osano.consent.getConsent === 'function') {
            return osano.consent.getConsent(category);
          }
          return undefined;
        };

        const updateOsanoConsent = (state) => {
          const osano = window.Osano || window.osano;
          if (!osano) return;
          const setter =
            typeof osano.setConsent === 'function'
              ? osano.setConsent
              : osano.consent && typeof osano.consent.setConsent === 'function'
                ? osano.consent.setConsent
                : undefined;
          if (!setter) return;

          const payload = {
            necessary: true,
            analytics: state.analytics,
            statistics: state.analytics,
            marketing: state.marketing,
          };

          try {
            if (setter.length >= 2) {
              setter('statistics', payload.statistics);
              setter('marketing', payload.marketing);
            } else {
              setter(payload);
            }
          } catch (error) {
            console.error('Osano consent update failed', error);
          }
        };

        const loadOptionalScript = (category) => {
          const entry = optionalScripts.find((item) => item.category === category);
          if (!entry || entry.loaded) return;
          const script = document.createElement('script');
          script.src = entry.src;
          script.async = true;
          script.onload = () => {
            entry.loaded = true;
            if (window.emailjs && typeof window.emailjs.init === 'function') {
              window.emailjs.init(EMAILJS_PUBLIC_KEY);
              if (window.__poligamiaEmailJsReadyResolver) {
                window.__poligamiaEmailJsReadyResolver(window.emailjs);
              }
            }
          };
          document.head.appendChild(script);
        };

        window.__poligamiaEmailJsReady = new Promise((resolve) => {
          window.__poligamiaEmailJsReadyResolver = resolve;
        });

        let currentConsent = {
          analytics: false,
          marketing: false,
        };

        const applyConsent = (consent, { persist = true, hide = true } = {}) => {
          currentConsent = {
            analytics: consent.analytics,
            marketing: consent.marketing,
          };

          if (consent.marketing) {
            loadOptionalScript('marketing');
          }

          if (persist) {
            saveConsent(currentConsent);
            updateOsanoConsent(currentConsent);
          }

          if (hide) {
            banner?.classList.add('is-hidden');
          }
        };

        const parseDetail = (detail) => {
          if (!detail) return {};
          const consentSource = detail.consent || detail.choices || detail;
          return {
            marketing: interpretConsent(consentSource.marketing),
            analytics: interpretConsent(consentSource.statistics ?? consentSource.analytics),
          };
        };

        const synchronizeConsent = () => {
          const osanoAnalytics = interpretConsent(getOsanoCategory('statistics') ?? getOsanoCategory('analytics'));
          const osanoMarketing = interpretConsent(getOsanoCategory('marketing'));
          if (osanoAnalytics || osanoMarketing) {
            applyConsent({ analytics: osanoAnalytics, marketing: osanoMarketing }, { persist: true, hide: true });
          }
        };

        const handleConsentEvent = (event) => {
          const parsed = parseDetail(event?.detail);
          const newConsent = {
            analytics: parsed.analytics ?? currentConsent.analytics,
            marketing: parsed.marketing ?? currentConsent.marketing,
          };
          applyConsent(newConsent, { persist: true, hide: true });
        };

        const showBanner = () => {
          banner?.classList.remove('is-hidden');
        };

        const showSettings = () => {
          settingsPanel?.setAttribute('aria-hidden', 'false');
          settingsPanel?.classList.add('is-visible');
        };

        const closeSettings = () => {
          settingsPanel?.setAttribute('aria-hidden', 'true');
          settingsPanel?.classList.remove('is-visible');
        };

        const loadStored = loadConsent();
        if (loadStored) {
          applyConsent(
            {
              analytics: loadStored.analytics ?? false,
              marketing: loadStored.marketing ?? false,
            },
            { persist: false, hide: true }
          );
        } else {
          showBanner();
        }

        window.addEventListener('OsanoOnConsentReady', handleConsentEvent);
        window.addEventListener('OsanoOnConsentChanged', handleConsentEvent);

        banner?.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const action = target.getAttribute('data-action');
          if (!action) return;
          if (action === 'accept-all') {
            applyConsent({ analytics: true, marketing: true });
          }
          if (action === 'reject-all') {
            applyConsent({ analytics: false, marketing: false });
          }
          if (action === 'open-settings') {
            settingsPanel?.classList.add('is-visible');
            settingsPanel?.setAttribute('aria-hidden', 'false');
          }
        });

        settingsPanel?.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const action = target.getAttribute('data-action');
          if (action === 'save-settings') {
            const preference = {
              analytics: analyticsToggle?.checked ?? false,
              marketing: marketingToggle?.checked ?? false,
            };
            applyConsent(preference);
          }
          if (action === 'close-settings') {
            closeSettings();
          }
        });

        settingsButton?.addEventListener('click', () => {
          closeSettings();
          showBanner();
          const stored = loadConsent();
          if (stored) {
            analyticsToggle?.setAttribute('checked', stored.analytics ? 'true' : 'false');
            marketingToggle?.setAttribute('checked', stored.marketing ? 'true' : 'false');
            analyticsToggle.checked = stored.analytics;
            marketingToggle.checked = stored.marketing;
          }
        });

        synchronizeConsent();
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .cookie-banner,
  .cookie-settings {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.85);
    z-index: 2000;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .cookie-banner.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .cookie-settings {
    opacity: 0;
    pointer-events: none;
  }

  .cookie-settings.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .cookie-card {
    max-width: 640px;
    width: 100%;
    background: #0f0f0f;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
  }

  .cookie-card h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .cookie-card p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
  }

  .cookie-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .cookie-btn {
    border-radius: 999px;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    border: 1px solid transparent;
    transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .cookie-btn.primary {
    background: #f1c88b;
    color: #111;
  }

  .cookie-btn.secondary {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  .cookie-btn.ghost {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.9);
  }

  .cookie-btn:hover {
    transform: translateY(-1px);
  }

  .cookie-options {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cookie-option {
    display: grid;
    gap: 0.3rem;
    font-family: var(--font-body);
  }

  .cookie-option input {
    transform: scale(1.1);
    margin-right: 0.5rem;
  }

  .cookie-label {
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .cookie-desc {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .cookie-settings-button {
    position: fixed;
    left: 1.5rem;
    bottom: 1.5rem;
    background: rgba(0, 0, 0, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0;
    border-radius: 999px;
    cursor: pointer;
    z-index: 1500;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .cookie-icon {
    width: 22px;
    height: 22px;
  }

  @media (max-width: 768px) {
    .cookie-banner,
    .cookie-settings {
      padding: 1.25rem;
    }

    .cookie-card {
      padding: 1.5rem;
      border-radius: 16px;
    }

    .cookie-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .cookie-btn {
      width: 100%;
      text-align: center;
    }

    .cookie-settings-button {
      left: 1rem;
      bottom: 1rem;
    }
  }
</style>
